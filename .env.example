# ─── Database ───────────────────────────────────────────────
# Local (docker-compose) default; override with Neon/Supabase URL in prod
DATABASE_URL="postgresql://crm:crm@localhost:5432/crm?schema=public"

# ─── Redis (cache, BullMQ queues, Socket.IO adapter) ────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (custom NestJS JWT + RBAC + TOTP MFA) ─────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
MFA_ISSUER="CRM Lead & Sales"

# ─── API ────────────────────────────────────────────────────
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# ─── Object storage (recordings, exports) — Phase 3 ─────────
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="crm-recordings"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ─── Calling provider (Twilio) — Phase 3 ────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_API_KEY=""
TWILIO_API_SECRET=""
TWILIO_TWIML_APP_SID=""
TWILIO_CALLER_ID=""

# ─── OpenPhone (calling / SMS) ──────────────────────────────
# Leave blank to run in SANDBOX mode. Set the API key to hit the real API.
OPENPHONE_API_KEY=""
OPENPHONE_BASE_URL="https://api.openphone.com/v1"
OPENPHONE_TIMEOUT_MS="10000"
# OPENPHONE_SANDBOX="true"   # force sandbox even when a key is set
OPENPHONE_WEBHOOK_SECRET=""   # HMAC secret to verify POST /api/webhooks/quo

# ─── Quo integration (Lead sync) ───────────────────────────
# Leave blank to run in SANDBOX mode (simulated Quo responses, no real calls).
# Set base URL + API key to hit the real Quo API (auth: API key header).
QUO_BASE_URL=""
QUO_API_KEY=""
QUO_TIMEOUT_MS="10000"
# QUO_SANDBOX="true"   # force sandbox even when creds are set

# ─── AI (Claude / Anthropic, swappable) — Phase 5 ───────────
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
# OPENAI_API_KEY=""   # alternative provider

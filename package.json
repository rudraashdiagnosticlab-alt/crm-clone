{
  "name": "crm",
  "version": "0.1.0",
  "private": true,
  "description": "CRM Lead & Sales System — outbound-calling sales CRM",
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace=@crm/api",
    "dev:web": "npm run dev --workspace=@crm/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run -w @crm/database generate",
    "db:migrate": "npm run -w @crm/database migrate",
    "db:seed": "npm run -w @crm/database seed",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "prettier": "^3.8.4"
  },
  "engines": {
    "node": ">=20"
  }
}
